# --- Database ---------------------------------------------------------------
# Local Postgres example: postgresql://postgres:postgres@localhost:5432/nexora
DATABASE_URL="postgresql://user:password@localhost:5432/nexora"

# --- Auth.js / NextAuth ------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Placeholder external services (wire these up before real launch) ------
# Razorpay — leave these unset (or containing "placeholder") to run against
# the built-in mock gateway (see lib/razorpay.ts), which fully simulates the
# booking payment flow without a live Razorpay account.
RAZORPAY_KEY_ID="placeholder"
RAZORPAY_KEY_SECRET="placeholder"
# From the Razorpay Dashboard → Webhooks, once you add the endpoint below.
RAZORPAY_WEBHOOK_SECRET="placeholder"
# Configure this URL as your webhook in the Razorpay Dashboard:
#   https://<your-domain>/api/webhooks/razorpay
# Subscribe to: payment.captured, payment.failed, refund.processed

# Transactional email (Resend/SendGrid/Postmark) — currently just logs to console
EMAIL_FROM="no-reply@nexora.example"
EMAIL_PROVIDER_API_KEY="placeholder"

# SMS/OTP provider (Twilio/MSG91) — currently UI-only, not connected
SMS_PROVIDER_API_KEY="placeholder"
